/* 色卡库页面 */
.page-swatch {
  min-height: 100vh;
  overflow-x: hidden;
  background: #F7F4F0;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

/* ---- 顶部标题 ---- */
.swatch-header {
  padding: 40rpx 32rpx 24rpx;
  display: flex;
  flex-direction: column;
}

.swatch-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #2C2520;
  letter-spacing: 4rpx;
}

.swatch-title-en {
  font-size: 18rpx;
  color: rgba(139,115,85,0.35);
  letter-spacing: 6rpx;
  margin-top: 4rpx;
}

.swatch-subtitle {
  font-size: 24rpx;
  color: #8A8078;
  margin-top: 16rpx;
}

/* ---- 面料分类横滑 ---- */
.fabric-tabs {
  padding: 0 32rpx;
  margin-top: 8rpx;
}

.fabric-tab-list {
  display: flex;
  gap: 16rpx;
  padding: 8rpx 0 16rpx;
}

.fabric-tab {
  flex-shrink: 0;
  padding: 14rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #8A8078;
  background: rgba(255,255,255,0.8);
  border: 1rpx solid rgba(0,0,0,0.04);
  transition: all 0.3s ease;
}

.fabric-tab-active {
  color: #FFFFFF;
  background: linear-gradient(135deg, #8B7355, #A6896B);
  border-color: transparent;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(139,115,85,0.25);
}

/* ---- 当前面料简介 ---- */
.fabric-brief {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
}

.brief-left {
  display: flex;
  flex-direction: column;
}

.brief-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C2520;
}

.brief-en {
  font-size: 20rpx;
  color: rgba(139,115,85,0.4);
  letter-spacing: 3rpx;
  margin-top: 2rpx;
  text-transform: uppercase;
}

.brief-count {
  font-size: 24rpx;
  color: #8B7355;
  background: rgba(139,115,85,0.08);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

/* ---- 色卡网格 ---- */
.swatch-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding: 0 32rpx;
}

.swatch-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  animation: fadeInUp 0.4s ease-out forwards;
  opacity: 0;
}

.swatch-color {
  width: 100%;
  height: 180rpx;
  position: relative;
  overflow: hidden;
}

.swatch-color-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.swatch-info {
  padding: 16rpx 20rpx;
  display: flex;
  flex-direction: column;
}

.swatch-number {
  font-size: 24rpx;
  font-weight: 600;
  color: #2C2520;
}

.swatch-name {
  font-size: 20rpx;
  color: #8A8078;
  margin-top: 2rpx;
}

/* ---- 其他面料 ---- */
.other-fabrics {
  margin-top: 48rpx;
  padding: 0 32rpx;
}

.other-title-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.other-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C2520;
  letter-spacing: 2rpx;
}

.other-title-en {
  font-size: 18rpx;
  color: rgba(139,115,85,0.35);
  letter-spacing: 4rpx;
}

.other-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.other-card {
  flex: 1;
  min-width: 200rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.other-colors {
  display: flex;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.other-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0,0,0,0.06);
}

.other-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2520;
  display: block;
}

.other-count {
  font-size: 22rpx;
  color: #8A8078;
  margin-top: 4rpx;
  display: block;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

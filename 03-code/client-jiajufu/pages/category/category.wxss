/* 面料分类页样式 */
.page-category {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #F7F3EF 0%, #F0EAE3 40%, #E6DED5 75%, #DDD4CA 100%);
  background-attachment: fixed;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

/* ---- 顶部栏 ---- */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  background: rgba(245, 240, 235, 0.72);
  backdrop-filter: saturate(180%) blur(40rpx);
  -webkit-backdrop-filter: saturate(180%) blur(40rpx);
  border-bottom: 1rpx solid rgba(255,255,255,0.6);
}

.search-icon-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-search {
  font-size: 32rpx;
}

.top-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: 2rpx;
}

.top-right-placeholder {
  width: 64rpx;
}

/* ---- 搜索展开层 ---- */
.search-expand {
  height: 0;
  overflow: hidden;
  transition: height 0.3s ease, opacity 0.3s ease;
  opacity: 0;
  padding: 0 32rpx;
}

.search-expand.search-show {
  height: 80rpx;
  opacity: 1;
  margin-bottom: 12rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: var(--color-card);
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 26rpx;
  color: var(--color-text);
  box-shadow: var(--shadow-card);
}

.search-placeholder {
  color: var(--color-text-light);
}

.search-close {
  font-size: 26rpx;
  color: var(--color-secondary);
  white-space: nowrap;
}

/* ---- 横向分类标签 ---- */
.cat-tabs {
  flex-shrink: 0;
  white-space: nowrap;
  border-bottom: 1rpx solid var(--color-border);
}

.cat-tabs-inner {
  display: inline-flex;
  padding: 0 24rpx 20rpx;
  gap: 8rpx;
}

.cat-tab {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--color-text-light);
  background: transparent;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.cat-tab-active {
  color: #FFFFFF;
  background: var(--color-secondary);
  font-weight: 500;
}

.cat-tab-count {
  font-size: 20rpx;
  opacity: 0.7;
}

/* ---- 内容区 ---- */
.content-scroll {
  flex: 1;
}

/* ---- 系列 Banner ---- */
.series-banner {
  position: relative;
  margin: 20rpx 24rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  height: 400rpx;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60%;
  background: linear-gradient(to top, rgba(0,0,0,0.5), transparent);
}

.banner-info {
  position: absolute;
  bottom: 32rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 1;
}

.banner-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
  letter-spacing: 2rpx;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  display: block;
}

.banner-tag {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  z-index: 1;
}

.banner-tag text {
  font-size: 20rpx;
  color: #FFFFFF;
  background: rgba(139, 115, 85, 0.85);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  letter-spacing: 2rpx;
}

/* ---- 双列瀑布流 ---- */
.grid-section {
  display: flex;
  padding: 12rpx 24rpx 32rpx;
  gap: 16rpx;
}

.grid-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.grid-col-right {
  margin-top: 48rpx;
}

.grid-card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  opacity: 0;
  transform: translateY(40rpx);
  transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.grid-card.visible {
  opacity: 1;
  transform: translateY(0);
}

.grid-img {
  width: 100%;
}

.grid-info {
  padding: 20rpx 20rpx 24rpx;
}

.grid-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
}

.grid-spec {
  font-size: 22rpx;
  color: var(--color-text-light);
  margin-top: 6rpx;
  display: block;
}

.grid-colors {
  display: flex;
  align-items: center;
  margin-top: 14rpx;
  gap: 8rpx;
}

.gc-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0,0,0,0.06);
}

.gc-more {
  font-size: 20rpx;
  color: var(--color-text-light);
}

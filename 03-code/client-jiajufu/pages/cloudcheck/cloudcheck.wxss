/* 云存储诊断页样式 */
.page {
  min-height: 100vh;
  background: #111111;
  color: #FFFFFF;
  padding-bottom: 160rpx;
}

.header {
  padding: 60rpx 32rpx 32rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.1);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  display: block;
  margin-top: 8rpx;
}

/* ---- 总览 ---- */
.summary {
  display: flex;
  padding: 32rpx;
  gap: 16rpx;
}

.sum-item {
  flex: 1;
  padding: 20rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.sum-item.ok   { background: rgba(52, 199, 89, 0.15);  }
.sum-item.fail { background: rgba(255, 59, 48, 0.15);  }
.sum-item.total{ background: rgba(255,255,255, 0.08);  }

.sum-num {
  font-size: 48rpx;
  font-weight: 700;
}

.sum-item.ok   .sum-num { color: #34C759; }
.sum-item.fail .sum-num { color: #FF3B30; }
.sum-item.total .sum-num{ color: #FFFFFF; }

.sum-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
}

/* ---- 检测中 ---- */
.checking-tip {
  padding: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
}

/* ---- 列表 ---- */
.list {
  padding: 0 24rpx;
}

.item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx 20rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.item-ok   { background: rgba(52, 199, 89, 0.08);  }
.item-fail { background: rgba(255, 59, 48, 0.12);  }

.item-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.item-info {
  flex: 1;
  overflow: hidden;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
  color: #FFFFFF;
}

.item-path {
  font-size: 20rpx;
  color: rgba(255,255,255,0.4);
  display: block;
  margin-top: 4rpx;
  word-break: break-all;
}

.item-err {
  font-size: 22rpx;
  color: #FF6B60;
  display: block;
  margin-top: 6rpx;
}

/* ---- 重检按钮 ---- */
.recheck-btn {
  position: fixed;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  background: #FFFFFF;
  color: #111111;
  font-size: 28rpx;
  font-weight: 600;
  padding: 24rpx 80rpx;
  border-radius: 60rpx;
}

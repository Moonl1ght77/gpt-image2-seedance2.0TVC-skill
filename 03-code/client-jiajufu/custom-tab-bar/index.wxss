/* 自定义 tabBar — 毛玻璃高级风 */
.tab-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 130rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(26, 22, 18, 0.88);
  backdrop-filter: saturate(180%) blur(40rpx);
  -webkit-backdrop-filter: saturate(180%) blur(40rpx);
  z-index: 999;
  border-top: 1rpx solid rgba(255,255,255,0.06);
  box-shadow: 0 -4rpx 30rpx rgba(0,0,0,0.15);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  position: relative;
  transition: all 0.3s ease;
}

.tab-icon-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
}

/* 选中指示线 */
.tab-indicator {
  position: absolute;
  top: -14rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 5rpx;
  border-radius: 3rpx;
  background: linear-gradient(135deg, #A6896B, #C4A882);
  box-shadow: 0 2rpx 8rpx rgba(166,137,107,0.5);
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  transition: transform 0.25s ease;
}

.tab-selected .tab-icon {
  transform: scale(1.15);
}

.tab-text {
  font-size: 22rpx;
  color: #7A7068;
  margin-top: 6rpx;
  letter-spacing: 2rpx;
  font-weight: 400;
  transition: all 0.3s ease;
}

.tab-selected .tab-text {
  color: #C4A882;
  font-weight: 600;
}

<view class="tab-bar">
  <view
    class="tab-item {{selected === index ? 'tab-selected' : ''}}"
    wx:for="{{tabs}}"
    wx:key="key"
    bindtap="switchTab"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
  >
    <view class="tab-icon-wrap">
      <view class="tab-indicator" wx:if="{{selected === index}}"></view>
      <image class="tab-icon" src="{{selected === index ? item.activeIcon : item.icon}}" mode="aspectFit" />
    </view>
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
